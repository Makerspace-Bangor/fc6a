# stock fstab - you probably want to override this with a machine specific one

/dev/root            /                    auto       defaults              1  1
proc                 /proc                proc       defaults              0  0
devpts               /dev/pts             devpts     mode=0620,gid=5       0  0
usbdevfs             /proc/bus/usb        usbdevfs   noauto                0  0
tmpfs                /run                 tmpfs      mode=0755,nodev,nosuid,strictatime 0  0
tmpfs                /var/volatile        tmpfs      defaults,size=50M     0  0

# folder for idec
tmpfs		     /home/idec/.tmp	  tmpfs	     mode=0777,nodev,suid,noatime,nodiratime,size=20M    0  0
tmpfs		     /home/idec/.work	  tmpfs	     mode=0777,nodev,suid,noatime,nodiratime,size=10M    0  0
tmpfs		     /home/idec/usr/tmp   tmpfs	     mode=0777,noexec,nodev,nosuid,noatime,nodiratime,size=100M   0  0
/dev/mtdblock16      /home/idec/rom       yaffs2     defaults,noexec,nodev,nosuid,sync   0  0
/dev/mtdblock17      /mnt/work            yaffs2     defaults,noexec,nodev,nosuid,sync   0  0

# mount user data area as /home/idec/rom
# mount with idec_init.sh
